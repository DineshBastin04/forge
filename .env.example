# Tychons Forge — Environment Variables
# Copy this file to .env and fill in your values

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Session signing key — must be long and random in production
SECRET_KEY=change-me-before-production
# bcrypt work factor — 12 for production, 10 for faster dev
BCRYPT_ROUNDS=12

# ─── Data directory ───────────────────────────────────────────────────────────
# Where agents.db and db_configs.json are stored (default: ./data/)
DATA_DIR=./data

# ─── Scheduler intervals ─────────────────────────────────────────────────────
DEVICE_RESET_SCHEDULE_HOURS=2
UNPICK_SCHEDULE_HOURS=2

# ─── DB connection pool (shared by scheduler jobs) ───────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─── Concurrency ──────────────────────────────────────────────────────────────
# Number of Waitress worker threads — 8 is suitable for up to ~20 concurrent users
WAITRESS_THREADS=8

# ─── App ──────────────────────────────────────────────────────────────────────
FLASK_PORT=5001
FLASK_DEBUG=false

# ─── Metadata DB (MSSQL) ──────────────────────────────────────────────────────
# Connection settings for storing users, configs, and logs.
# Leave USER/PASSWORD blank to use Windows Authentication (Trusted Connection).
METADATA_DB_SERVER=localhost
METADATA_DB_DATABASE=tychons_forge
METADATA_DB_USER=
METADATA_DB_PASSWORD=
METADATA_DB_DRIVER=SQL Server
# Alternatively, specify a full connection string directly:
# METADATA_DB_CONN_STR=DRIVER={SQL Server};SERVER=localhost;DATABASE=tychons_forge;Trusted_Connection=yes;
